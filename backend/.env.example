# Kopieer dit bestand naar .env en vul je eigen waarden in.

# --- Database ---
# LOKAAL (SQLite):
DATABASE_URL="file:./dev.db"
# PRODUCTIE (Supabase PostgreSQL) — voorbeeld:
# DATABASE_URL="postgresql://postgres:[WACHTWOORD]@db.[PROJECT].supabase.co:5432/postgres"

# --- Beveiliging ---
# Geheim voor het ondertekenen van inlog-tokens (verander dit in productie!)
JWT_SECRET=wk-poule-2026-secret-key

# --- Frontend toegang (CORS) ---
# Komma-gescheiden lijst van toegestane origins. In productie de Netlify-URL.
# Voorbeeld:
# CORS_ORIGIN=https://wk-poule-2026.netlify.app
CORS_ORIGIN=http://localhost:5173

# --- Automatisch uitslagen ophalen (optioneel) ---
# API-key van football-data.org (https://www.football-data.org/client/register)
FOOTBALL_DATA_API_KEY=
