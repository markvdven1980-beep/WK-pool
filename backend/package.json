{
  "name": "wk-poule-2026-backend",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "prisma generate && tsc",
    "build:prod": "node scripts/gen-prod-schema.mjs && prisma generate --schema=prisma/schema.production.prisma && tsc",
    "start": "node dist/index.js",
    "postinstall": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:push": "prisma db push",
    "db:push:prod": "node scripts/gen-prod-schema.mjs && prisma db push --schema=prisma/schema.production.prisma --accept-data-loss",
    "db:seed": "tsx prisma/seed.ts",
    "db:seed:prod": "node scripts/gen-prod-schema.mjs && prisma generate --schema=prisma/schema.production.prisma && tsx prisma/seed.ts",
    "db:reset": "prisma migrate reset --force"
  },
  "dependencies": {
    "@prisma/client": "^6.9.0",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.5",
    "express": "^4.21.0",
    "jsonwebtoken": "^9.0.2"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.7",
    "prisma": "^6.9.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  }
}
