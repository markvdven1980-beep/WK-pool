# Kopieer naar .env voor lokale overrides (meestal niet nodig — de Vite-proxy regelt /api lokaal).
#
# In productie (Netlify) stel je deze in als environment variable:
# de volledige URL van je backend, zonder /api en zonder slash op het eind.
# Voorbeeld:
# VITE_API_URL=https://wk-poule-backend.onrender.com
VITE_API_URL=
